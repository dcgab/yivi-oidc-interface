# Yivi OIDC provider local configuration.
# Copy to yivi-consent-node/.env or run scripts/setup-local-env.sh.
# Values marked CHANGE_ME are development placeholders and must be regenerated
# or replaced before any real deployment.

NODE_ENV=development
PORT=3000

# Backend service URLs
HYDRA_PUBLIC_URL=http://127.0.0.1:4444
HYDRA_ADMIN_URL=http://hydra:4445
IRMA_SERVER_URL=http://irma_server:8088
IRMA_SERVER_PUBLIC_URL=http://127.0.0.1:8088
IRMA_SERVER_TOKEN=
YIVI_BACKEND_PUBLIC_URL=http://127.0.0.1:3000

# Yivi client frontend build-time config
VITE_YIVI_BACKEND_URL=http://127.0.0.1:3000
VITE_YIVI_FRONTEND_DEBUG=true

# Debug flags
YIVI_BACKEND_DEBUG=true

# Hydra runtime config
HYDRA_POSTGRES_USER=ory
HYDRA_POSTGRES_PASSWORD=CHANGE_ME_GENERATED_HYDRA_POSTGRES_PASSWORD
HYDRA_POSTGRES_DB=hydra
HYDRA_DSN=postgres://ory:CHANGE_ME_GENERATED_HYDRA_POSTGRES_PASSWORD@postgresd_hydra:5432/hydra?sslmode=disable&max_conns=20&max_idle_conns=4
HYDRA_SECRETS_SYSTEM=CHANGE_ME_GENERATED_HYDRA_SYSTEM_SECRET
HYDRA_SUBJECT_PAIRWISE_SALT=CHANGE_ME_GENERATED_HYDRA_PAIRWISE_SALT
HYDRA_ISSUER_URL=http://127.0.0.1:4444
HYDRA_SELF_PUBLIC_URL=http://127.0.0.1:4444/
HYDRA_LOGIN_URL=http://127.0.0.1:3000/login
HYDRA_CONSENT_URL=http://127.0.0.1:3000/consent
HYDRA_LOGOUT_URL=http://127.0.0.1:3000/logout

# Caddy/deployment hostnames. Local development normally does not use Caddy.
CADDY_OIDC_HOST=oidc.example.test
CADDY_YIVI_FRONTEND_HOST=yivi.example.test
CADDY_YIVI_SERVER_HOST=yivi-server.example.test
CADDY_DEMO_APP_HOST=demo-app.example.test

# Generated local Yivi runtime files
YIVI_RUNTIME_DIR=./yivi-consent-node/runtime/yivi
YIVI_REQUESTER_ID=oryhydra
YIVI_REQUESTER_TOKEN=CHANGE_ME_GENERATED_YIVI_REQUESTER_TOKEN
YIVI_REQUESTER_CONFIG_FILE=./yivi-consent-node/runtime/yivi/irmaserver.json
YIVI_JWT_PRIVATE_KEY_FILE=./yivi-consent-node/runtime/yivi/private.pem
YIVI_JWT_PUBLIC_KEY_FILE=./yivi-consent-node/runtime/yivi/public.pem

# Client creation defaults
OIDC_CLIENT_NAME=Yivi Login
OIDC_CLIENT_LOGO_URI=https://www.ru.nl/themes/custom/ru/logo.svg
OIDC_CLIENT_REDIRECT_URI=http://127.0.0.1:4433/self-service/methods/oidc/callback/yivi
OIDC_CLIENT_SCOPES=openid,pbdf.sidn-pbdf.email.email,pbdf.sidn-pbdf.mobilenumber.mobilenumber,pbdf.gemeente.personalData.firstnames,pbdf.gemeente.personalData.familyname
PRINT_GENERATED_CLIENT_SECRET=false
