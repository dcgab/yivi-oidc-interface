{
  "name": "vite-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "ts-node-dev src/server.ts",
    "start": "NODE_ENV=production tsx src/server.ts",
