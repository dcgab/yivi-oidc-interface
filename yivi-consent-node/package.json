    "@types/node": "^26.0.1",
    "autoprefixer": "^10.5.2",
    "fast-xml-parser": "^5.9.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4.3.1",
    "ts-node-dev": "^2.0.0",
    "vite": "^8.1.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "dependencies": {
    "@ory/client": "^1.22.57",
    "@privacybydesign/yivi-client": "^1.0.0",
    "@privacybydesign/yivi-core": "^1.0.0",
    "@privacybydesign/yivi-css": "^1.0.1",
