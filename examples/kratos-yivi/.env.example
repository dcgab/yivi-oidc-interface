# Kratos/Yivi example local configuration.
# Copy to examples/kratos-yivi/.env or run scripts/setup-local-env.sh.
# Values marked CHANGE_ME are development placeholders and must be regenerated
# or replaced before any real deployment.

NODE_ENV=development

# Kratos database
KRATOS_POSTGRES_USER=ory
KRATOS_POSTGRES_PASSWORD=CHANGE_ME_GENERATED_KRATOS_POSTGRES_PASSWORD
KRATOS_POSTGRES_DB=kratos
KRATOS_DSN=postgres://ory:CHANGE_ME_GENERATED_KRATOS_POSTGRES_PASSWORD@postgresd_kratos:5432/kratos?sslmode=disable&max_conns=20&max_idle_conns=4
KRATOS_HOST_DSN=postgres://ory:CHANGE_ME_GENERATED_KRATOS_POSTGRES_PASSWORD@127.0.0.1:5433/kratos?sslmode=disable&max_conns=20&max_idle_conns=4

# Kratos public/admin/UI URLs
KRATOS_PUBLIC_URL=http://127.0.0.1:4433/
KRATOS_INTERNAL_PUBLIC_URL=http://host.docker.internal:4433/
KRATOS_ADMIN_URL=http://kratos:4434/
KRATOS_BROWSER_URL=http://127.0.0.1:4433/
KRATOS_DEFAULT_BROWSER_RETURN_URL=http://127.0.0.1:4000/
KRATOS_ALLOWED_RETURN_URLS=http://127.0.0.1:4000,http://127.0.0.1:4455,http://localhost:19006/Callback,exp://localhost:8081/--/Callback
KRATOS_UI_PUBLIC_URL=http://127.0.0.1:4455
KRATOS_UI_INTERNAL_PUBLIC_URL=http://kratos-selfservice-ui-node:4455
KRATOS_LOG_LEVEL=debug
KRATOS_LEAK_SENSITIVE_VALUES=true

# Kratos UI secrets
KRATOS_UI_COOKIE_SECRET=CHANGE_ME_GENERATED_KRATOS_UI_COOKIE_SECRET
KRATOS_UI_CSRF_COOKIE_NAME=ory_csrf_ui
KRATOS_UI_CSRF_COOKIE_SECRET=CHANGE_ME_GENERATED_KRATOS_UI_CSRF_SECRET
KRATOS_UI_PORT=4455
KRATOS_UI_SECURITY_MODE=

# Kratos application secrets
KRATOS_COOKIE_SECRET=CHANGE_ME_GENERATED_KRATOS_COOKIE_SECRET
KRATOS_CIPHER_SECRET=CHANGE_ME_GENERATED_32_BYTE_KRATOS_CIPHER_SECRET

# OIDC provider used by Kratos
HYDRA_ADMIN_URL=http://hydra:4445/
YIVI_OIDC_ISSUER_URL=http://127.0.0.1:4444
YIVI_OIDC_CLIENT_ID=CHANGE_ME_CREATED_BY_CREATE_CLIENT_SCRIPT
YIVI_OIDC_CLIENT_SECRET=CHANGE_ME_CREATED_BY_CREATE_CLIENT_SCRIPT
YIVI_OIDC_REDIRECT_URI=http://127.0.0.1:4433/self-service/methods/oidc/callback/yivi
YIVI_OIDC_SCOPES=openid,offline,email,profile,pbdf.sidn-pbdf.email.email,pbdf.sidn-pbdf.mobilenumber.mobilenumber,pbdf.gemeente.personalData.firstnames,pbdf.gemeente.personalData.familyname
YIVI_OIDC_CLIENT_NAME=Yivi Login

# Demo app
ORY_AUTH_DEMO_PORT=4000
ORY_SDK_URL=http://host.docker.internal:4433
ORY_UI_URL=http://127.0.0.1:4455
APP_URL=http://127.0.0.1:4000
